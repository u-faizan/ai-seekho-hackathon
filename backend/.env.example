# ==============================================================================
# Autonomous Business Operations Agent — Environment Variables Template
# Copy this file to .env and fill in your actual credentials.
# ==============================================================================

# --- System & Deployment ---
ENV=development
HOST=127.0.0.1
PORT=8000
DATABASE_URL=sqlite:///./sandbox.db

# --- AI Provider Configuration ---
# Options: 'gemini' (native) or 'openrouter' (proxy)
LLM_PROVIDER=openrouter

# --- Google Gemini API (Native) ---
# Get your API key: https://aistudio.google.com/
# Models used: gemini-2.0-flash-lite (text) and gemini-2.0-flash (PDF File API)
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenRouter API (Fallback/Temporary) ---
# Models used: google/gemini-2.0-flash-lite-001 via proxy
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-001

# --- Firebase Authentication ---
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Key
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# --- Optional: Mock Services ---
MOCK_SMTP_ENABLED=true
MOCK_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here
